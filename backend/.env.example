# ── CORE INFRASTRUCTURE ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── DATABASE VECTORS ───────────────────────────────────────────────────────
# PostgreSQL Cloud URI (e.g. postgresql://user:pass@ep-hostname.us-east-2.aws.neon.tech/neondb)
DATABASE_URL=postgresql://localhost:5432/intellicampus

# MongoDB Atlas URI (e.g. mongodb+srv://user:pass@cluster0.abc.mongodb.net/intellicampus)
MONGO_URI=mongodb://localhost:27017/intellicampus

# ── SECURITY ───────────────────────────────────────────────────────────────
JWT_SECRET=intellicampus_neural_key_2026
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=intellicampus_refresh_key_2026
JWT_REFRESH_EXPIRES_IN=7d

# ── AI ENGINE (OPTIONAL) ────────────────────────────────────────────────────
AI_API_KEY=your_gemini_api_key_here

# ── SMTP (COMMUNICATION) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_NAME=IntelliCampus
FROM_EMAIL=noreply@intellicampus.com
